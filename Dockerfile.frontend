FROM python:3.14-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock README.md ./
COPY frontend.py ./

RUN uv sync --frozen

EXPOSE 8501

CMD ["uv", "run", "streamlit", "run", "frontend.py", "--server.address=0.0.0.0", "--server.port=8501"]